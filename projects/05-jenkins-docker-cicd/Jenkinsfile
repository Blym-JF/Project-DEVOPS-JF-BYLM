pipeline {
  agent any
  stages {
    stage('Clone') {
      steps {
        echo 'Cloning repository...'
      }
    }
    stage('Build Docker image') {
      steps {
        script {
          docker.image('nginx:alpine').pull()
          def image = docker.build("demo-jenkins-docker:${BUILD_NUMBER}", "./app")
        }
      }
    }
    stage('Run container') {
      steps {
        script {
          docker.image("demo-jenkins-docker:${BUILD_NUMBER}").inside {
            sh 'echo "Container running with demo app"'
          }
        }
      }
    }
  }
  post {
    always {
      echo 'Pipeline completed'
    }
  }
}
